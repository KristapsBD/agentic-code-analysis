# LLM Provider API Keys
# Get your API keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/settings/keys

OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Default Configuration
# Options: openai, anthropic
DEFAULT_PROVIDER=openai

# Model Selection
# OpenAI models: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Anthropic models: claude-3-5-sonnet-20241022, claude-3-opus-20240229, claude-3-sonnet-20240229
DEFAULT_MODEL_OPENAI=gpt-4o
DEFAULT_MODEL_ANTHROPIC=claude-3-5-sonnet-20241022

# Debate Configuration
# Number of debate rounds per vulnerability claim (1-5)
DEFAULT_DEBATE_ROUNDS=2

# LLM Temperature (0.0 = deterministic, 2.0 = creative)
# Lower values recommended for security analysis
DEFAULT_TEMPERATURE=0.7

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
