# LLM Provider API Keys
# Get your API keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/settings/keys
# - Google Gemini: https://makersuite.google.com/app/apikey

OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Default Configuration
# Options: openai, anthropic, gemini
# RECOMMENDED FOR TESTING: gemini (free tier available)
DEFAULT_PROVIDER=gemini

# Model Selection
# OpenAI models: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Anthropic models: claude-3-5-sonnet-20241022, claude-3-opus-20240229, claude-3-sonnet-20240229
# Gemini models: gemini-2.0-flash-exp (FREE), gemini-1.5-flash, gemini-1.5-pro
DEFAULT_MODEL_OPENAI=gpt-4o
DEFAULT_MODEL_ANTHROPIC=claude-3-5-sonnet-20241022
DEFAULT_MODEL_GEMINI=gemini-2.0-flash-exp

# Debate Configuration
# Number of debate rounds per vulnerability claim (1-5)
DEFAULT_DEBATE_ROUNDS=2

# Temperature Configuration (0.0 = deterministic, 2.0 = very creative)
# Each setting controls a specific phase of the pipeline independently.
# TEMP_ATTACKER_SCAN  — initial vulnerability scan; slightly higher for broader coverage
# TEMP_DEBATE         — attacker/defender argument rounds; focused but not rigid
# TEMP_CLARIFICATION  — factual answers to judge questions; low for precision
# TEMP_JUDGE          — verdict rendering; low for consistency and reproducibility
TEMP_ATTACKER_SCAN=0.4
TEMP_DEBATE=0.3
TEMP_CLARIFICATION=0.2
TEMP_JUDGE=0.2

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
